# Copy to .env and set your Neon connection string (never commit .env).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
PORT=3001

# Required for JWT sign/verify (use a long random string in production).
JWT_SECRET="change-me-to-a-long-random-secret"

# Nuxt dev server (comma-separated for multiple origins).
CORS_ORIGIN="http://localhost:3000"
